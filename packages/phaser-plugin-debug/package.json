{
  "name": "@letumfalx/phaser-plugin-debug",
  "version": "1.0.0",
  "description": "A phaser plugin that adds a debug function to your game instance.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/letumfalx/phaser-utils.git",
    "directory": "packages/phaser-plugin-debug"
  },
  "author": {
    "name": "letum",
    "email": "dletumfalx@gmail.com",
    "url": "https://github.com/letumfalx"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/esm/index.js",
  "exports": {
    ".": {
      "default": "./dist/esm/index.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm-run-all --parallel build:*",
    "build:cjs": "bun build --format=cjs --outdir=dist/cjs --outfile=index.js --external=debug,phaser --packages=external --target=browser src/index.ts",
    "build:esm": "bun build --format=esm --outdir=dist/esm --outfile=index.js --external=debug,phaser --packages=external --target=browser src/index.ts",
    "build:types": "tsc --project tsconfig.build.json",
    "lint:check": "eslint .",
    "lint:fix": "eslint --fix .",
    "type:check": "tsc --noEmit"
  },
  "peerDependencies": {
    "debug": "*",
    "phaser": "^3.8.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "^1.3.9",
    "@types/debug": "^4.1.12",
    "eslint": "^10.0.0",
    "npm-run-all2": "^8.0.4",
    "typescript": "^5.9.3"
  }
}
